<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.teach.javafx.controller.base.ApplyRegisterController"
           styleClass="apply-root">

    <VBox alignment="CENTER" spacing="20">

        <Label text="账号申请" styleClass="page-title"/>

        <VBox spacing="14" styleClass="apply-card">

            <TextField fx:id="usernameField"
                       promptText="请输入账号"
                       styleClass="neo-input"/>

            <TextField fx:id="nameField"
                       promptText="请输入姓名"
                       styleClass="neo-input"/>

            <TextField fx:id="emailField"
                       promptText="请输入邮箱"
                       styleClass="neo-input"/>

            <PasswordField fx:id="passwordField"
                           promptText="请输入密码"
                           styleClass="neo-input"/>

            <PasswordField fx:id="confirmPasswordField"
                           promptText="再次输入密码"
                           styleClass="neo-input"/>

            <ComboBox fx:id="roleComboBox"
                      promptText="选择申请角色"
                      styleClass="neo-combo"/>

            <Button text="提交申请"
                    onAction="#onSubmitButtonClick"
                    styleClass="neo-btn-primary"/>

            <Button text="返回登录"
                    onAction="#onBackButtonClick"
                    styleClass="neo-btn-light"/>

        </VBox>

    </VBox>

</StackPane>