<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" prefHeight="680.0" prefWidth="1100.0" styleClass="root-pane" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.teach.javafx.controller.TeacherController">


    <top>
        <VBox spacing="14.0" styleClass="top-wrapper">
            <children>

                <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="header-card">
                    <children>
                        <VBox spacing="4.0">
                            <children>
                                <Label styleClass="page-title" text="👨‍🏫 教师信息管理" />
                                <Label styleClass="page-subtitle" text="支持查询、编辑、保存、删除，以及外观切换" />
                            </children>
                        </VBox>

                        <HBox HBox.hgrow="ALWAYS" />

                        <VBox alignment="CENTER_RIGHT" spacing="6.0">
                            <children>
                                <Label styleClass="small-label" text="阅读模式" />
                                <ComboBox fx:id="themeComboBox" prefWidth="140.0" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="toolbar-card">
                    <children>
                        <Button onAction="#onAddButtonClick" styleClass="btn-success" text="新增一行" />

                        <Button onAction="#onQueryButtonClick" styleClass="btn-primary" text="刷新" />

                        <FlowPane HBox.hgrow="ALWAYS" />

                        <Label styleClass="query-label" text="工号 / 姓名" />
                        <TextField fx:id="numNameTextField" prefWidth="180.0" promptText="请输入工号或姓名" styleClass="query-field" />

                        <Button onAction="#onQueryButtonClick" styleClass="btn-primary" text="查询" />
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="status-card">
                    <children>
                        <Label styleClass="status-title" text="状态：" />
                        <Label fx:id="statusLabel" styleClass="status-text" text="系统就绪" />
                    </children>
                </HBox>

            </children>
            <padding>
                <Insets bottom="10.0" left="18.0" right="18.0" top="18.0" />
            </padding>
        </VBox>
    </top>

    <center>
        <VBox styleClass="table-wrapper">
            <children>
                <TableView fx:id="dataTableView" editable="true" styleClass="teacher-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="numColumn" prefWidth="140.0" text="工号" />
                        <TableColumn fx:id="nameColumn" prefWidth="140.0" text="姓名" />
                        <TableColumn fx:id="deptColumn" prefWidth="220.0" text="院系" />
                        <TableColumn fx:id="titleColumn" prefWidth="150.0" text="职称" />
                        <TableColumn fx:id="degreeColumn" prefWidth="150.0" text="学历" />
                        <TableColumn fx:id="operateColumn" prefWidth="240.0" text="操作" />
                    </columns>
                </TableView>
            </children>
            <padding>
                <Insets bottom="18.0" left="18.0" right="18.0" top="0.0" />
            </padding>
        </VBox>
    </center>

</BorderPane>
