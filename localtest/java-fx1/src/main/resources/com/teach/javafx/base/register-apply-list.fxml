<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.teach.javafx.controller.base.RegisterApplyController"
            styleClass="audit-root">

    <top>
        <StackPane styleClass="top-banner">
            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 15 25 15 25;">
                <VBox spacing="4">
                    <Label text="账号申请审核中心" styleClass="page-title"/>
                    <Label text="教师 / 管理员申请统一审核入口，支持多维度筛选" styleClass="page-subtitle"/>
                </VBox>
            </HBox>
        </StackPane>
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 15 25 20 25;">

            <HBox spacing="15">
                <HBox spacing="15">
                    <VBox prefWidth="180" styleClass="stat-card, stat-pending">
                        <Label text="待审核" styleClass="stat-title"/>
                        <Label fx:id="pendingCountLabel" text="0" styleClass="stat-number"/>
                    </VBox>
                    <VBox prefWidth="180" styleClass="stat-card, stat-approved">
                        <Label text="已通过" styleClass="stat-title"/>
                        <Label fx:id="approvedCountLabel" text="0" styleClass="stat-number"/>
                    </VBox>
                    <VBox prefWidth="180" styleClass="stat-card, stat-rejected">
                        <Label text="已拒绝" styleClass="stat-title"/>
                        <Label fx:id="rejectedCountLabel" text="0" styleClass="stat-number"/>
                    </VBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <HBox spacing="12" alignment="CENTER_RIGHT" styleClass="query-card">
                    <TextField fx:id="keywordField" promptText="输入用户名 / 姓名" styleClass="neo-input" prefWidth="160"/>
                    <ComboBox fx:id="statusComboBox" prefWidth="120" styleClass="neo-combo"/>
                    <Button text="查询" onAction="#onQueryButtonClick" styleClass="neo-btn-primary"/>
                    <Button text="刷新" onAction="#onRefreshButtonClick" styleClass="neo-btn-info"/>
                    <Button text="重置" onAction="#onResetButtonClick" styleClass="neo-btn-light"/>
                </HBox>
            </HBox>

            <VBox spacing="10" VBox.vgrow="ALWAYS" styleClass="table-card">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="申请列表" styleClass="section-title"/>
                    <Label fx:id="countLabel" text="共 0 条记录" styleClass="count-label"/>
                </HBox>

                <TableView fx:id="applyTable" VBox.vgrow="ALWAYS" styleClass="audit-table">
                    <columns>
                        <TableColumn fx:id="applyIdColumn" text="申请ID" prefWidth="80"/>
                        <TableColumn fx:id="usernameColumn" text="用户名" prefWidth="110"/>
                        <TableColumn fx:id="nameColumn" text="姓名" prefWidth="100"/>
                        <TableColumn fx:id="roleColumn" text="角色" prefWidth="90"/>
                        <TableColumn fx:id="deptColumn" text="院系" prefWidth="130"/>
                        <TableColumn fx:id="phoneColumn" text="电话" prefWidth="110"/>
                        <TableColumn fx:id="emailColumn" text="邮箱" prefWidth="160"/>
                        <TableColumn fx:id="applyTimeColumn" text="申请时间" prefWidth="160"/>
                        <TableColumn fx:id="statusColumn" text="状态" prefWidth="90"/>
                        <TableColumn fx:id="reasonColumn" text="申请原因" prefWidth="180"/>
                        <TableColumn fx:id="actionColumn" text="操作" prefWidth="160"/>
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </center>
</BorderPane>